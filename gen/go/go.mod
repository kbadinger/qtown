// Module for buf-generated Go protobuf/gRPC code (the cross-service contract).
// Regenerated by `buf generate` (see proto/buf.gen.yaml → out: ../gen/go).
// buf only writes qtown/*.pb.go here; this go.mod is hand-maintained.
// Consumed by Go services via a replace directive, e.g. in market-district:
//   require qtown/proto v0.0.0
//   replace qtown/proto => ../../gen/go
module qtown/proto

go 1.25.0

require (
	google.golang.org/grpc v1.82.0
	google.golang.org/protobuf v1.36.11
)

require (
	golang.org/x/net v0.55.0 // indirect
	golang.org/x/sys v0.45.0 // indirect
	golang.org/x/text v0.37.0 // indirect
	google.golang.org/genproto/googleapis/rpc v0.0.0-20260414002931-afd174a4e478 // indirect
)
