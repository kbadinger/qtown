# Copy to .env and fill in. NEVER commit the real .env (it's .dockerignored + should be .gitignored).

# Cloudflare Tunnel token.
# Cloudflare dashboard → Zero Trust → Networks → Tunnels → Create a tunnel →
# (cloudflared) → copy the token from the "run" command it shows you.
TUNNEL_TOKEN=

# Optional driver tuning.
DRIVER_RESOURCES=gold,wood,grain,stone
DRIVER_INTERVAL_MS=800
