# Qwen Town — Environment Variables
# Copy this file to .env and fill in your values

# Admin API key (generate a random string)
QTOWN_ADMIN_KEY=change-me-to-a-random-string

# Environment: development or production
QTOWN_ENV=development

# Local SQLite database (dev)
DATABASE_URL=sqlite:///./town.db

# Production Postgres (Neon)
PROD_DATABASE_URL=postgresql://user:password@your-neon-host.neon.tech/dbname?sslmode=require

# Railway deployment
DEPLOY_URL=https://your-app.up.railway.app
DEPLOY_TIMEOUT=300
RAILWAY_TOKEN=your-railway-token
RAILWAY_PROJECT_ID=your-project-id

# Domain (optional)
DOMAIN_URL=https://qtown.ai

# Ollama (local LLM)
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=qwen3.5:27b

# Alert webhook (optional — Discord, ntfy.sh, or generic POST)
# Leave blank to just write alerts to alerts.log
ALERT_WEBHOOK_URL=
