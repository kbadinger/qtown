# Qwen Town — Environment Variables
# Copy this file to .env and fill in your values

# Admin API key (generate a random string)
QTOWN_ADMIN_KEY=change-me-to-a-random-string

# Environment: development or production
QTOWN_ENV=development

# Local SQLite database (dev)
DATABASE_URL=sqlite:///./town.db

# Production Postgres (Neon)
PROD_DATABASE_URL=postgresql://user:password@your-neon-host.neon.tech/dbname?sslmode=require

# Railway deployment
DEPLOY_URL=https://your-app.up.railway.app
DEPLOY_TIMEOUT=300
RAILWAY_TOKEN=your-railway-token
RAILWAY_PROJECT_ID=your-project-id

# Domain (optional)
DOMAIN_URL=https://qtown.ai

# Ollama (local LLM)
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=qwen3.5:27b

# Telegram notifications (recommended)
# 1. Message @BotFather on Telegram, /newbot, get the token
# 2. Message your bot, then GET https://api.telegram.org/bot<TOKEN>/getUpdates to find chat_id
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ComfyUI (sprite generation — optional, skip if no GPU)
COMFY_URL=http://127.0.0.1:8188
COMFY_OUTPUT_DIR=D:\AICartoon\ComfyUI\ComfyUI\output
